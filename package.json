{
  "name": "weekly-report-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:server": "cd server && node server.js",
    "dev:client": "cd client && npx vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npx vite build",
    "start": "cd server && NODE_ENV=production node server.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
